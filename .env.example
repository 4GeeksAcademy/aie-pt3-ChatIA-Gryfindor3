# Ejemplo de variables de entorno
# NO subas un archivo `.env` real con tu API key al repositorio.
# Recomendado: variable de entorno server-side (no expuesta al cliente)
GROQ_API_KEY=tu_api_key_aqui

# Si por alguna razón necesitas exponer una clave pública (NO recomendado):
# NEXT_PUBLIC_GROQ_API_KEY=tu_api_key_publica_aqui
